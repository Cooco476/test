<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover">
    <title>🍃 电子资产库 · 定制绿</title>
    <style>
        /* ===== 使用指定颜色： #248057 (深林绿) / #83CBAC (浅薄荷绿) ===== */
        :root {
            --bg-page: #eef8f2;                /* 极浅绿底 */
            --bg-card: #ffffff;
            --text-primary: #1e2a2a;
            --text-secondary: #4a5c5c;
            --text-tertiary: #7a8e8e;
            --border-light: #cfe6db;
            --accent-deep: #248057;            /* 深绿主色 */
            --accent-light: #83CBAC;           /* 浅绿辅助 */
            --accent-soft: #e0f3ea;            /* 极浅绿背景 */
            --shadow-sm: 0 2px 8px rgba(0, 30, 20, 0.02), 0 4px 12px rgba(0, 30, 20, 0.03);
            --shadow-md: 0 6px 16px rgba(0, 30, 20, 0.04);
            --badge-active-bg: #e0f3ea;
            --badge-active-text: #1d6b47;
            --badge-retired-bg: #fff1e6;
            --badge-retired-text: #9a3f0e;
            --badge-sold-bg: #e6f7ec;
            --badge-sold-text: #0b6e41;
            --warranty-valid: #248057;
            --warranty-expired: #b91c1c;
            --daily-bg: #248057;
            --daily-text: white;
        }

        body.dark {
            --bg-page: #0e1a15;
            --bg-card: #1a2a22;
            --text-primary: #e2f0e8;
            --text-secondary: #a6c7b8;
            --text-tertiary: #6d8a7a;
            --border-light: #2a4038;
            --accent-deep: #3b8c6b;            /* 夜间调亮 */
            --accent-light: #5c9e82;
            --accent-soft: #1e3a2e;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
            --shadow-md: 0 6px 16px rgba(0, 0, 0, 0.3);
            --badge-active-bg: #1e3a2e;
            --badge-active-text: #a7f3d0;
            --badge-retired-bg: #3a2a1e;
            --badge-retired-text: #fbbf7c;
            --badge-sold-bg: #1a3a2a;
            --badge-sold-text: #86efac;
            --warranty-valid: #5cbf8f;
            --warranty-expired: #f87171;
            --daily-bg: #3b8c6b;
            --daily-text: #ffffff;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-page);
            color: var(--text-primary);
            min-height: 100vh;
            padding-bottom: 24px;
            transition: background 0.2s, color 0.2s;
        }

        .app-header {
            background: var(--bg-card);
            padding: 16px 20px;
            position: sticky;
            top: 0;
            z-index: 10;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
            backdrop-filter: blur(8px);
            background: rgba(from var(--bg-card) r g b / 0.9);
        }
        h1 {
            font-size: 1.7rem;
            font-weight: 650;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .header-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .theme-btn {
            background: none;
            border: 1.5px solid var(--border-light);
            border-radius: 40px;
            width: 42px;
            height: 42px;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-primary);
            background: var(--bg-card);
            transition: 0.15s;
        }
        .badge-local {
            background: var(--accent-soft);
            color: var(--accent-deep);
            padding: 6px 14px;
            border-radius: 40px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .container { max-width: 640px; margin: 0 auto; padding: 16px 18px; }
        .view { display: none; }
        .view.active { display: block; }

        /* 总花费卡片 — 使用 #83CBAC → #248057 渐变 */
        .total-card {
            background: linear-gradient(135deg, #83CBAC 0%, #248057 100%);
            border-radius: 28px;
            padding: 20px 22px;
            margin-bottom: 16px;
            color: white;
            box-shadow: var(--shadow-md);
        }
        body.dark .total-card {
            background: linear-gradient(135deg, #5c9e82 0%, #2a6b4e 100%);
        }

        .total-label { font-size: 0.9rem; opacity: 0.9; display: flex; justify-content: space-between; }
        .total-amount { font-size: 2.5rem; font-weight: 700; margin-top: 4px; }
        .total-detail { font-size: 0.85rem; opacity: 0.8; margin-top: 8px; }

        /* 筛选行 */
        .filter-row {
            display: flex; gap: 8px; margin-bottom: 12px; align-items: center; flex-wrap: wrap;
        }
        .filter-select, .sort-select {
            flex: 1; min-width: 100px; padding: 10px 12px;
            border: 1.5px solid var(--border-light);
            border-radius: 40px;
            background: var(--bg-card);
            font-size: 0.9rem;
            color: var(--text-primary);
        }
        .toggle-switch {
            display: flex; align-items: center; gap: 6px;
            background: var(--bg-card); padding: 8px 14px; border-radius: 40px;
            border: 1.5px solid var(--border-light); font-size: 0.85rem; white-space: nowrap;
            color: var(--text-primary);
        }
        .toggle-switch input { width: 18px; height: 18px; accent-color: var(--accent-deep); }

        .list-actions { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .btn-add {
            background: var(--accent-deep); color: white; border: none;
            padding: 12px 22px; border-radius: 60px; font-weight: 600;
            box-shadow: 0 6px 14px rgba(36, 128, 87, 0.2); cursor: pointer;
        }
        .stats { color: var(--text-secondary); font-size: 0.95rem; }

        /* 设备卡片 */
        .device-card {
            background: var(--bg-card); border-radius: 24px; padding: 18px;
            margin-bottom: 14px; box-shadow: var(--shadow-sm);
            border: 1px solid var(--border-light); cursor: pointer;
        }
        .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .category-icon { font-size: 1.8rem; line-height: 1; }
        .device-title { font-weight: 700; font-size: 1.2rem; flex:1; color: var(--text-primary); }
        .status-badge {
            font-size: 0.7rem; padding: 4px 10px; border-radius: 40px; font-weight: 600;
            background: var(--badge-active-bg); color: var(--badge-active-text);
        }
        .status-retired { background: var(--badge-retired-bg); color: var(--badge-retired-text); }
        .status-sold { background: var(--badge-sold-bg); color: var(--badge-sold-text); }

        .date-warranty-row {
            display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
            font-size: 0.9rem; color: var(--text-secondary);
        }
        .warranty-text { font-weight: 600; font-size: 0.8rem; }
        .warranty-valid-text { color: var(--warranty-valid); }
        .warranty-expired-text { color: var(--warranty-expired); }
        .warranty-none-text { color: var(--text-tertiary); }

        .price-row {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 10px;
        }
        .channel-price { color: var(--text-secondary); font-size: 0.95rem; }
        .daily-cost-badge {
            background: var(--daily-bg); color: var(--daily-text);
            padding: 6px 14px; border-radius: 40px; font-weight: 700; font-size: 1rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

        .usage-row {
            display: flex; align-items: center; gap: 16px;
            font-size: 0.8rem; color: var(--text-tertiary);
            border-top: 1px solid var(--border-light); padding-top: 10px; margin-top: 4px;
        }
        .retire-info { font-size: 0.75rem; color: var(--text-tertiary); margin-top: 6px; }

        /* 表单卡片 */
        .form-card {
            background: var(--bg-card); border-radius: 32px;
            padding: 24px 20px; box-shadow: var(--shadow-md);
        }
        .back-bar { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
        .btn-back { background: none; border: none; font-size: 2rem; cursor: pointer; color: var(--accent-deep); }
        .form-group { margin-bottom: 18px; }
        label { font-weight: 600; font-size: 0.9rem; display: block; margin-bottom: 6px; color: var(--text-primary); }
        .required::after { content: " *"; color: #dc2626; }
        input, select, textarea {
            width: 100%; padding: 12px 14px;
            border: 1.5px solid var(--border-light);
            border-radius: 18px; font-size: 1rem;
            background: var(--bg-card); color: var(--text-primary);
        }
        .row-2 { display: flex; gap: 12px; }
        .row-2 .form-group { flex: 1; }
        .warranty-inline { display: flex; gap: 8px; align-items: center; }
        .warranty-inline input { width: 100px; }
        .warranty-inline select { width: 100px; }

        .checkbox-group {
            display: flex; align-items: center; gap: 24px;
            margin-top: 12px; flex-wrap: wrap;
        }
        .checkbox-item {
            display: flex; align-items: center; gap: 8px;
            cursor: pointer; font-size: 0.95rem; color: var(--text-primary);
        }
        .checkbox-item input[type="checkbox"] {
            width: 20px; height: 20px; accent-color: var(--accent-deep);
            margin: 0; padding: 0;
        }

        .section-title {
            font-weight: 700; margin: 24px 0 12px; font-size: 1.1rem;
            color: var(--text-primary);
        }
        .item-list { background: var(--bg-page); border-radius: 20px; padding: 6px 0; margin-bottom: 10px; }
        .list-item {
            display: flex; align-items: center; justify-content: space-between;
            padding: 10px 14px; border-bottom: 1px solid var(--border-light);
            color: var(--text-primary);
        }
        .list-item:last-child { border-bottom: none; }
        .item-delete { color: var(--text-tertiary); background: none; border: none; font-size: 1.2rem; cursor: pointer; }
        .add-item-btn {
            background: var(--bg-card); border: 1.5px dashed var(--border-light);
            color: var(--accent-deep); padding: 12px; border-radius: 40px;
            width: 100%; font-weight: 600; margin: 8px 0 16px; cursor: pointer;
        }
        .cost-summary {
            background: var(--accent-soft); border-radius: 24px;
            padding: 16px 18px; margin: 20px 0; display: flex;
            justify-content: space-between; align-items: center;
            color: var(--text-primary);
        }
        .avg-cost-large { font-size: 1.6rem; font-weight: 700; color: var(--accent-deep); }
        .btn { padding: 14px; border-radius: 60px; font-weight: 600; border: none; cursor: pointer; }
        .btn-primary { background: var(--accent-deep); color: white; }
        .btn-outline { background: var(--bg-card); border: 1.5px solid var(--border-light); color: var(--text-primary); }
        .btn-danger { background: var(--bg-card); border: 1.5px solid #fecaca; color: #b91c1c; }
        .form-actions { display: flex; gap: 12px; margin-top: 20px; }
        footer { text-align: center; margin-top: 28px; color: var(--text-tertiary); font-size: 0.8rem; }
        .empty-state {
            text-align: center; padding: 48px 24px; background: var(--bg-card);
            border-radius: 36px; color: var(--text-tertiary);
            border: 1px dashed var(--border-light);
        }
        .hint { font-size: 0.75rem; color: var(--text-tertiary); margin-top: 4px; }
    </style>
</head>
<body>
<div class="app-header">
    <h1>🍃 资产库</h1>
    <div class="header-actions">
        <span class="badge-local">🔒 本地</span>
        <button class="theme-btn" id="themeToggle" title="切换深色/浅色">🌙</button>
    </div>
</div>
<div class="container">
    <!-- 列表视图 -->
    <div id="listView" class="view active">
        <div class="total-card">
            <div class="total-label">
                <span>📊 总净花费</span>
                <span id="totalCountDisplay">0 件</span>
            </div>
            <div class="total-amount" id="totalSpendDisplay">¥0</div>
            <div class="total-detail" id="totalDetailDisplay">含附属·维修·扣除回血</div>
        </div>

        <div class="filter-row">
            <select id="filterStatus" class="filter-select">
                <option value="all">📋 全部状态</option>
                <option value="active">✅ 服役中</option>
                <option value="retired">⚰️ 已退役</option>
                <option value="sold">💰 已回收</option>
            </select>
            <select id="filterCategory" class="filter-select">
                <option value="all">📂 全部分类</option>
            </select>
            <select id="sortSelect" class="filter-select sort-select">
                <option value="date-desc">📅 入手日期 (新→旧)</option>
                <option value="price-desc">💰 价格 (高→低)</option>
                <option value="daily-desc">📊 日均成本 (高→低)</option>
                <option value="usage-desc">⏱️ 使用时长 (长→短)</option>
            </select>
        </div>
        <div style="display: flex; justify-content: flex-end; margin-bottom: 14px;">
            <label class="toggle-switch">
                <input type="checkbox" id="hideRetiredSoldToggle"> 🚫 隐藏退役/回收
            </label>
        </div>

        <div class="list-actions">
            <span class="stats" id="statsText">0 件设备</span>
            <button class="btn-add" id="showAddFormBtn">➕ 新增</button>
        </div>
        <div id="deviceListContainer"></div>
        <div id="emptyMessage" class="empty-state" style="display: none;">📭 还没有记录，点击新增</div>
    </div>

    <!-- 表单视图 -->
    <div id="formView" class="view">
        <div class="back-bar">
            <button class="btn-back" id="backToListBtn">←</button>
            <h2 id="formTitle">新增产品</h2>
        </div>
        <div class="form-card">
            <input type="hidden" id="editId" value="">
            <div class="form-group">
                <label class="required">📂 分类</label>
                <select id="categorySelect"></select>
            </div>
            <div class="row-2">
                <div class="form-group"><label class="required">品牌</label><input id="brand" placeholder="Apple"></div>
                <div class="form-group"><label class="required">产品名</label><input id="product" placeholder="iPhone 16 Pro"></div>
            </div>
            <div class="form-group"><label class="required">📅 入手日期</label><input type="date" id="purchaseDate"></div>
            
            <div class="form-group">
                <label class="required">⏳ 质保时长</label>
                <div class="warranty-inline">
                    <input type="number" id="warrantyValue" min="0" value="12">
                    <select id="warrantyUnit">
                        <option value="years">年</option>
                        <option value="months" selected>月</option>
                    </select>
                </div>
                <div class="checkbox-group">
                    <label class="checkbox-item">
                        <input type="checkbox" id="noWarranty"> 🚫 无质保
                    </label>
                    <label class="checkbox-item">
                        <input type="checkbox" id="lifetimeWarranty"> ❤️ 终身质保
                    </label>
                </div>
            </div>

            <div class="row-2">
                <div class="form-group"><label>💰 入手价格</label><input type="number" id="price" step="0.01" placeholder="0.00"></div>
                <div class="form-group">
                    <label>🛒 入手渠道</label>
                    <select id="channel">
                        <option value="">未选择</option>
                        <option value="闲鱼">闲鱼</option>
                        <option value="拼多多">拼多多</option>
                        <option value="京东">京东</option>
                        <option value="淘宝">淘宝</option>
                        <option value="天猫">天猫</option>
                        <option value="官网">官网</option>
                        <option value="其他">其他</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label>📌 设备状态</label>
                <select id="statusSelect">
                    <option value="active" selected>✅ 服役中</option>
                    <option value="retired">⚰️ 已退役 (坏掉/不用)</option>
                    <option value="sold">💰 已回收 (卖出)</option>
                </select>
            </div>
            <div id="retireDateGroup" class="form-group" style="display:none;">
                <label>📅 退役/卖出日期</label>
                <input type="date" id="retireDate">
            </div>
            <div id="sellPriceGroup" class="form-group" style="display:none;">
                <label>💵 回血金额</label>
                <input type="number" id="sellPrice" step="0.01" placeholder="卖出价格">
            </div>

            <div class="section-title">🧾 附属费用</div>
            <div id="extraCostList" class="item-list"></div>
            <button class="add-item-btn" id="addExtraCostBtn">➕ 添加附属费用</button>

            <div class="section-title">🔧 维修记录</div>
            <div id="repairList" class="item-list"></div>
            <button class="add-item-btn" id="addRepairBtn">➕ 添加维修记录</button>

            <div class="cost-summary" id="costPreview">
                <span>📊 单天平均成本</span>
                <span class="avg-cost-large" id="avgCostDisplay">¥0.00</span>
            </div>
            <div style="font-size:0.8rem; color: var(--text-tertiary); margin-top:-8px;">(净花费 ÷ 实际使用天数)</div>

            <div class="form-actions">
                <button class="btn btn-primary" id="saveBtn">保存</button>
                <button class="btn btn-outline" id="cancelEditBtn">取消</button>
            </div>
            <button class="btn btn-danger" id="deleteBtn" style="display:none; margin-top:12px;">🗑️ 删除记录</button>
        </div>
    </div>
    <footer>🍃 数据仅存于本设备 · 关闭不丢失</footer>
</div>
<script>
    (function(){
        "use strict";
        const STORAGE_KEY = 'electronics_archive_v10';
        const THEME_KEY = 'app_theme';
        const CATEGORIES = [
            { name: '耳机', icon: '🎧' }, { name: '空调', icon: '❄️' }, { name: '手机', icon: '📱' },
            { name: '洗地机', icon: '🧹' }, { name: '相机', icon: '📷' }, { name: '电脑', icon: '💻' },
            { name: '平板', icon: '📟' }, { name: '手表', icon: '⌚' }, { name: '游戏机', icon: '🎮' },
            { name: '音箱', icon: '🔊' }, { name: '显示器', icon: '🖥️' }, { name: '键盘', icon: '⌨️' },
            { name: '鼠标', icon: '🖱️' }, { name: '其他', icon: '📦' }
        ];

        let devices = [];
        let currentFilter = { status: 'all', category: 'all' };
        let currentSort = 'date-desc';
        let hideRetiredSold = false;

        // DOM 元素
        const listView = document.getElementById('listView'), formView = document.getElementById('formView');
        const container = document.getElementById('deviceListContainer'), emptyMsg = document.getElementById('emptyMessage');
        const statsText = document.getElementById('statsText'), totalSpendDisplay = document.getElementById('totalSpendDisplay');
        const totalDetailDisplay = document.getElementById('totalDetailDisplay'), totalCountDisplay = document.getElementById('totalCountDisplay');
        const filterStatus = document.getElementById('filterStatus'), filterCategory = document.getElementById('filterCategory');
        const sortSelect = document.getElementById('sortSelect');
        const hideToggle = document.getElementById('hideRetiredSoldToggle');
        const categorySelect = document.getElementById('categorySelect');
        const editId = document.getElementById('editId'), formTitle = document.getElementById('formTitle');
        const brand = document.getElementById('brand'), product = document.getElementById('product');
        const dateInput = document.getElementById('purchaseDate');
        const warrantyVal = document.getElementById('warrantyValue'), warrantyUnit = document.getElementById('warrantyUnit');
        const noWarranty = document.getElementById('noWarranty');
        const lifetimeWarranty = document.getElementById('lifetimeWarranty');
        const price = document.getElementById('price'), channel = document.getElementById('channel');
        const statusSelect = document.getElementById('statusSelect');
        const retireDateGroup = document.getElementById('retireDateGroup'), retireDate = document.getElementById('retireDate');
        const sellPriceGroup = document.getElementById('sellPriceGroup'), sellPrice = document.getElementById('sellPrice');
        const deleteBtn = document.getElementById('deleteBtn');
        const avgCostDisplay = document.getElementById('avgCostDisplay');
        
        let tempExtraCosts = [], tempRepairs = [];

        // 主题切换
        const themeToggle = document.getElementById('themeToggle');
        function setTheme(isDark) {
            if (isDark) {
                document.body.classList.add('dark');
                themeToggle.textContent = '☀️';
            } else {
                document.body.classList.remove('dark');
                themeToggle.textContent = '🌙';
            }
            localStorage.setItem(THEME_KEY, isDark ? 'dark' : 'light');
        }
        const savedTheme = localStorage.getItem(THEME_KEY);
        setTheme(savedTheme === 'dark');
        themeToggle.addEventListener('click', () => setTheme(!document.body.classList.contains('dark')));

        function initCategorySelects() {
            const options = CATEGORIES.map(c => `<option value="${c.name}">${c.icon} ${c.name}</option>`).join('');
            categorySelect.innerHTML = options;
            filterCategory.innerHTML = '<option value="all">📂 全部分类</option>' + options;
        }
        initCategorySelects();

        // 工具函数
        function formatDateCN(d) { if(!d||isNaN(d.getTime())) return ''; return `${d.getFullYear()}年${d.getMonth()+1}月${d.getDate()}日`; }
        function daysBetween(start, end) { return Math.max(0, Math.floor((end - start) / (1000*60*60*24))); }
        function calcExpiry(purchase, val, unit) {
            if(!purchase) return null; const d = new Date(purchase); if(isNaN(d)) return null;
            const num = parseFloat(val); if(isNaN(num)) return null;
            const exp = new Date(d); 
            if(unit==='years') exp.setFullYear(exp.getFullYear() + num);
            else exp.setMonth(exp.getMonth() + num);
            return exp;
        }
        function isExpired(exp) { if(!exp) return false; const t=new Date(); t.setHours(0,0,0,0); exp.setHours(0,0,0,0); return t>exp; }
        function getRemainingDays(expiryDate) {
            if(!expiryDate) return null;
            const today = new Date(); today.setHours(0,0,0,0);
            const exp = new Date(expiryDate); exp.setHours(0,0,0,0);
            return Math.floor((exp - today) / (1000*60*60*24));
        }

        function computeCostsAndDays(dev) {
            const priceNum = parseFloat(dev.price) || 0;
            const extraTotal = (dev.extraCosts || []).reduce((s, e) => s + (parseFloat(e.amount)||0), 0);
            const repairTotal = (dev.repairs || []).reduce((s, r) => s + (parseFloat(r.cost)||0), 0);
            let gross = priceNum + extraTotal + repairTotal;
            let sell = (dev.status === 'sold' && dev.sellPrice) ? parseFloat(dev.sellPrice) : 0;
            const net = gross - sell;

            const purchase = dev.purchaseDate ? new Date(dev.purchaseDate) : null;
            let endDate = new Date();
            if ((dev.status === 'retired' || dev.status === 'sold') && dev.retireDate) endDate = new Date(dev.retireDate);
            let days = 0;
            if (purchase && !isNaN(purchase) && !isNaN(endDate)) days = daysBetween(purchase, endDate);
            const avg = days > 0 ? net / days : 0;
            return { gross, sell, net, days, avg };
        }

        function getFilteredAndSortedDevices() {
            let filtered = devices.filter(d => {
                if (hideRetiredSold && d.status !== 'active') return false;
                if (!hideRetiredSold) {
                    if (currentFilter.status !== 'all' && d.status !== currentFilter.status) return false;
                }
                if (currentFilter.category !== 'all' && d.category !== currentFilter.category) return false;
                return true;
            });
            
            filtered.sort((a, b) => {
                const costA = computeCostsAndDays(a), costB = computeCostsAndDays(b);
                switch(currentSort) {
                    case 'date-desc': return (b.purchaseDate||'').localeCompare(a.purchaseDate||'');
                    case 'price-desc': return (parseFloat(b.price)||0) - (parseFloat(a.price)||0);
                    case 'daily-desc': return costB.avg - costA.avg;
                    case 'usage-desc': return costB.days - costA.days;
                    default: return 0;
                }
            });
            return filtered;
        }

        function updateTotalCard() {
            const filtered = getFilteredAndSortedDevices();
            const totalNet = filtered.reduce((sum, d) => sum + computeCostsAndDays(d).net, 0);
            totalSpendDisplay.textContent = `¥${totalNet.toFixed(2)}`;
            const totalAllNet = devices.reduce((sum, d) => sum + computeCostsAndDays(d).net, 0);
            totalDetailDisplay.textContent = `总计 ${devices.length} 件 · 净花费 ¥${totalAllNet.toFixed(2)}`;
            totalCountDisplay.textContent = `${devices.length} 件`;
        }

        function renderList() {
            const filtered = getFilteredAndSortedDevices();
            statsText.textContent = `共 ${devices.length} 件，当前显示 ${filtered.length} 件`;
            if (filtered.length === 0) {
                container.innerHTML = '';
                emptyMsg.style.display = 'block';
                updateTotalCard();
                return;
            }
            emptyMsg.style.display = 'none';
            let html = '';
            filtered.forEach(d => {
                const costs = computeCostsAndDays(d);
                const cat = CATEGORIES.find(c=>c.name===d.category) || {icon:'📦', name:d.category||'其他'};
                
                let warrantyStatusText = '', warrantyClass = '';
                let remainingDays = null;
                if (d.lifetimeWarranty) {
                    warrantyStatusText = '终身质保'; warrantyClass = 'warranty-valid-text';
                } else if (d.noWarranty) {
                    warrantyStatusText = '无质保'; warrantyClass = 'warranty-none-text';
                } else if (d.purchaseDate) {
                    const exp = calcExpiry(d.purchaseDate, d.warrantyValue, d.warrantyUnit);
                    if (exp) {
                        if (isExpired(exp)) { warrantyStatusText = '已过保'; warrantyClass = 'warranty-expired-text'; }
                        else { warrantyStatusText = '质保中'; warrantyClass = 'warranty-valid-text'; remainingDays = getRemainingDays(exp); }
                    }
                }
                
                const statusMap = { active:'服役中', retired:'已退役', sold:'已回收' };
                const statusClass = d.status==='active'?'':(d.status==='retired'?'status-retired':'status-sold');
                const channelShow = d.channel?.trim() || '无';
                const priceShow = d.price ? `¥${parseFloat(d.price).toFixed(2)}` : '无';
                const purchaseShow = d.purchaseDate ? formatDateCN(new Date(d.purchaseDate)) : '未填日期';
                
                let usageDays = costs.days;
                let usageText = usageDays > 0 ? `${usageDays} 天` : '不足1天';
                
                const retireInfo = [];
                if(d.status==='retired') retireInfo.push(`退役: ${d.retireDate||'?'}`);
                if(d.status==='sold') retireInfo.push(`回血 ¥${d.sellPrice||0}`);
                
                html += `<div class="device-card" data-id="${d.id}">
                    <div class="card-header">
                        <span class="category-icon">${cat.icon}</span>
                        <span class="device-title">${d.brand||'?'} ${d.product||''}</span>
                        <span class="status-badge ${statusClass}">${statusMap[d.status]}</span>
                    </div>
                    <div class="date-warranty-row">
                        <span>📅 ${purchaseShow}</span>
                        <span class="warranty-text ${warrantyClass}">🛡️ ${warrantyStatusText}</span>
                    </div>
                    <div class="price-row">
                        <span class="channel-price">${channelShow} · ${priceShow}</span>
                        <span class="daily-cost-badge">日均 ¥${costs.avg.toFixed(2)}</span>
                    </div>
                    <div class="usage-row">
                        <span>⏱️ 已使用 ${usageText}</span>
                        ${d.lifetimeWarranty ? '<span>🛡️ 终身</span>' : (!d.noWarranty && remainingDays !== null && remainingDays >= 0 ? `<span>🛡️ 剩余质保 ${remainingDays} 天</span>` : '')}
                    </div>
                    ${retireInfo.length? `<div class="retire-info">${retireInfo.join(' · ')}</div>`:''}
                </div>`;
            });
            container.innerHTML = html;
            document.querySelectorAll('.device-card').forEach(c=>c.addEventListener('click', ()=>openEdit(c.dataset.id)));
            updateTotalCard();
        }

        function renderExtraCostList() {
            const div = document.getElementById('extraCostList');
            if(!tempExtraCosts.length) { div.innerHTML='<div style="padding:14px;color:var(--text-tertiary);text-align:center;">暂无附属费用</div>'; return; }
            div.innerHTML = tempExtraCosts.map((item,idx)=>`
                <div class="list-item"><span>${item.name||'未命名'}</span><span>¥${parseFloat(item.amount||0).toFixed(2)}</span><button class="item-delete" data-type="extra" data-idx="${idx}">✕</button></div>
            `).join('');
            div.querySelectorAll('.item-delete').forEach(btn=>btn.addEventListener('click', e=>{
                const idx=btn.dataset.idx; tempExtraCosts.splice(idx,1); renderExtraCostList(); updateAvgPreview();
            }));
            updateAvgPreview();
        }
        function renderRepairList() {
            const div = document.getElementById('repairList');
            if(!tempRepairs.length) { div.innerHTML='<div style="padding:14px;color:var(--text-tertiary);text-align:center;">暂无维修记录</div>'; return; }
            div.innerHTML = tempRepairs.map((r,idx)=>`
                <div class="list-item"><span>${r.date||'?'} ${r.note||''}</span><span>¥${parseFloat(r.cost||0).toFixed(2)}</span><button class="item-delete" data-type="repair" data-idx="${idx}">✕</button></div>
            `).join('');
            div.querySelectorAll('.item-delete').forEach(btn=>btn.addEventListener('click', e=>{
                const idx=btn.dataset.idx; tempRepairs.splice(idx,1); renderRepairList(); updateAvgPreview();
            }));
            updateAvgPreview();
        }

        function promptAddExtra() {
            const name = prompt('附属费用名称')?.trim(); if(!name) return;
            const amt = prompt('金额')?.trim(); if(amt===null) return;
            const num = parseFloat(amt); if(isNaN(num)||num<0){alert('无效金额');return;}
            tempExtraCosts.push({name, amount:num}); renderExtraCostList();
        }
        function promptAddRepair() {
            let date = prompt('维修日期 (YYYY-MM-DD) 留空默认今天')?.trim();
            if(!date) { const d=new Date(); date = d.toISOString().slice(0,10); }
            const cost = prompt('维修费用')?.trim(); if(cost===null) return;
            const num = parseFloat(cost); if(isNaN(num)||num<0){alert('无效金额');return;}
            const note = prompt('备注')||''; tempRepairs.push({date, cost:num, note}); renderRepairList();
        }

        function updateAvgPreview() {
            const priceNum = parseFloat(price.value)||0;
            const extra = tempExtraCosts.reduce((s,e)=>s+(e.amount||0),0);
            const repair = tempRepairs.reduce((s,r)=>s+(r.cost||0),0);
            const gross = priceNum + extra + repair;
            const sell = (statusSelect.value==='sold' && sellPrice.value) ? parseFloat(sellPrice.value) : 0;
            const net = gross - sell;
            const purchase = dateInput.value ? new Date(dateInput.value) : null;
            let endDate = new Date();
            if ((statusSelect.value==='retired'||statusSelect.value==='sold') && retireDate.value) endDate = new Date(retireDate.value);
            let days = 0;
            if(purchase && !isNaN(purchase)) days = daysBetween(purchase, endDate);
            const avg = days>0 ? net/days : 0;
            avgCostDisplay.textContent = `¥${avg.toFixed(2)}`;
        }

        function toggleStatusFields() {
            const st = statusSelect.value;
            retireDateGroup.style.display = (st==='retired'||st==='sold') ? 'block' : 'none';
            sellPriceGroup.style.display = st==='sold' ? 'block' : 'none';
            updateAvgPreview();
        }
        
        function updateWarrantyInputs() {
            const noW = noWarranty.checked;
            const life = lifetimeWarranty.checked;
            if (life) {
                noWarranty.checked = false;
                warrantyVal.disabled = true;
                warrantyUnit.disabled = true;
            } else if (noW) {
                lifetimeWarranty.checked = false;
                warrantyVal.disabled = true;
                warrantyUnit.disabled = true;
            } else {
                warrantyVal.disabled = false;
                warrantyUnit.disabled = false;
            }
            updateAvgPreview();
        }
        noWarranty.addEventListener('change', updateWarrantyInputs);
        lifetimeWarranty.addEventListener('change', updateWarrantyInputs);

        statusSelect.addEventListener('change', toggleStatusFields);
        [brand,product,dateInput,price,warrantyVal,warrantyUnit,retireDate,sellPrice].forEach(el=>el.addEventListener('input', updateAvgPreview));

        function openEdit(deviceId=null) {
            listView.classList.remove('active'); formView.classList.add('active');
            if(deviceId) {
                const dev = devices.find(d=>d.id===deviceId); if(!dev) return;
                editId.value=dev.id; formTitle.textContent='编辑产品';
                categorySelect.value=dev.category||'其他';
                brand.value=dev.brand||''; product.value=dev.product||''; dateInput.value=dev.purchaseDate||'';
                warrantyVal.value=dev.warrantyValue||'12'; 
                warrantyUnit.value=dev.warrantyUnit||'months';
                noWarranty.checked=dev.noWarranty||false;
                lifetimeWarranty.checked=dev.lifetimeWarranty||false;
                price.value=dev.price||''; channel.value=dev.channel||'';
                statusSelect.value=dev.status||'active';
                retireDate.value=dev.retireDate||''; sellPrice.value=dev.sellPrice||'';
                tempExtraCosts = dev.extraCosts ? JSON.parse(JSON.stringify(dev.extraCosts)) : [];
                tempRepairs = dev.repairs ? JSON.parse(JSON.stringify(dev.repairs)) : [];
                deleteBtn.style.display='block';
            } else {
                editId.value=''; formTitle.textContent='新增产品';
                categorySelect.value='手机'; brand.value=product.value='';
                dateInput.value=new Date().toISOString().slice(0,10);
                warrantyVal.value='12'; warrantyUnit.value='months';
                noWarranty.checked=false; lifetimeWarranty.checked=false;
                price.value=''; channel.value=''; statusSelect.value='active';
                retireDate.value=sellPrice.value='';
                tempExtraCosts=[]; tempRepairs=[]; deleteBtn.style.display='none';
            }
            renderExtraCostList(); renderRepairList();
            updateWarrantyInputs();
            toggleStatusFields();
        }

        function save() {
            const id = editId.value || Date.now().toString()+Math.random().toString(36);
            const device = {
                id, category: categorySelect.value, brand: brand.value.trim(), product: product.value.trim(),
                purchaseDate: dateInput.value, warrantyValue: warrantyVal.value, warrantyUnit: warrantyUnit.value,
                noWarranty: noWarranty.checked, lifetimeWarranty: lifetimeWarranty.checked,
                price: price.value.trim(), channel: channel.value,
                status: statusSelect.value, retireDate: retireDate.value || null, sellPrice: sellPrice.value || null,
                extraCosts: tempExtraCosts, repairs: tempRepairs
            };
            if(!device.brand || !device.product) { alert('品牌和产品必填'); return; }
            if(editId.value) {
                const idx = devices.findIndex(d=>d.id===id); if(idx!==-1) devices[idx]=device;
            } else devices.push(device);
            localStorage.setItem(STORAGE_KEY, JSON.stringify(devices));
            renderList(); backToList();
        }
        function deleteCurrent() {
            if(!editId.value) return; if(!confirm('删除？')) return;
            devices = devices.filter(d=>d.id!==editId.value);
            localStorage.setItem(STORAGE_KEY, JSON.stringify(devices));
            renderList(); backToList();
        }
        function backToList() { formView.classList.remove('active'); listView.classList.add('active'); }

        function load() {
            const stored = localStorage.getItem(STORAGE_KEY);
            if(stored) { try{ devices=JSON.parse(stored); }catch(e){ devices=[]; } }
            if(devices.length===0) {
                devices.push({ 
                    id:'1', category:'耳机', brand:'Sony', product:'WH-1000XM6', 
                    purchaseDate:'2026-02-10', warrantyValue:'12', warrantyUnit:'months', 
                    noWarranty:false, lifetimeWarranty:false, price:'2299', channel:'京东', status:'active', 
                    extraCosts:[{name:'耳机架',amount:89}], repairs:[{date:'2026-03-01',cost:150,note:'更换耳罩'}] 
                });
            }
            renderList();
        }

        filterStatus.addEventListener('change', e => { currentFilter.status = e.target.value; renderList(); });
        filterCategory.addEventListener('change', e => { currentFilter.category = e.target.value; renderList(); });
        sortSelect.addEventListener('change', e => { currentSort = e.target.value; renderList(); });
        hideToggle.addEventListener('change', e => { hideRetiredSold = e.target.checked; renderList(); });

        document.getElementById('showAddFormBtn').addEventListener('click', ()=>openEdit());
        document.getElementById('backToListBtn').addEventListener('click', backToList);
        document.getElementById('cancelEditBtn').addEventListener('click', backToList);
        document.getElementById('saveBtn').addEventListener('click', save);
        deleteBtn.addEventListener('click', deleteCurrent);
        document.getElementById('addExtraCostBtn').addEventListener('click', promptAddExtra);
        document.getElementById('addRepairBtn').addEventListener('click', promptAddRepair);
        load();
    })();
</script>
</body>
</html>
